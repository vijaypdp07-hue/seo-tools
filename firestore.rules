rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection and Subcollections
    match /users/{userId} {
      function isSelf() {
        return isSignedIn() && request.auth.uid == userId;
      }

      allow read, write: if isSelf();

      // History Subcollection
      match /history/{historyId} {
        function isValidHistory(data) {
          return data.toolSlug is string && data.toolSlug.size() <= 100 &&
                 data.category is string && data.category.size() <= 100 &&
                 data.toolPath is string && data.toolPath.size() <= 200 &&
                 data.usedAt != null;
        }

        allow read, delete: if isSelf();
        allow create: if isSelf() && isValidHistory(request.resource.data);
        allow update: if false;
      }

      // Bookmarks Subcollection
      match /bookmarks/{bookmarkId} {
        function isValidBookmark(data) {
          return data.toolSlug is string && data.toolSlug.size() <= 100 &&
                 data.categoryName is string && data.categoryName.size() <= 100 &&
                 data.toolPath is string && data.toolPath.size() <= 200 &&
                 data.addedAt != null;
        }

        allow read, delete, update: if isSelf();
        allow create: if isSelf() && isValidBookmark(request.resource.data);
      }
    }
  }
}
